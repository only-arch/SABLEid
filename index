<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>SABLE Keeper Identification Terminal</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@500;700&family=Pretendard:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>

<style>
*{box-sizing:border-box;margin:0;padding:0}

:root{
  --theme:#1f3a66;
  --theme-dark:#132849;
  --gold:#c8a35a;
  --ink:#10233f;
  --paper:#fffdf8;
  --photo-x:0px;
  --photo-y:0px;
  --photo-scale:1;
}

body{
  min-height:100vh;
  font-family:Pretendard,sans-serif;
  color:#edf4ff;
  background:
    radial-gradient(circle at 20% 15%, rgba(200,163,90,.18), transparent 28%),
    radial-gradient(circle at 80% 10%, rgba(106,151,210,.22), transparent 32%),
    linear-gradient(135deg,#071321,#10233f 55%,#091522);
  padding:28px;
  overflow-x:hidden;
}

body::before{
  content:"";
  position:fixed;
  inset:0;
  pointer-events:none;
  background-image:
    linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
  background-size:42px 42px;
  mask-image:linear-gradient(to bottom, rgba(0,0,0,.8), transparent);
}

.terminal-header{
  max-width:1280px;
  margin:0 auto 22px;
  padding:20px 24px;
  border:1px solid rgba(200,163,90,.25);
  border-radius:24px;
  background:rgba(8,20,36,.62);
  backdrop-filter:blur(14px);
  box-shadow:0 20px 50px rgba(0,0,0,.22);
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:18px;
}

.header-title small{
  display:block;
  color:var(--gold);
  font-size:11px;
  letter-spacing:.22em;
  font-weight:800;
  margin-bottom:6px;
}

.header-title h1{
  font-family:"Noto Serif KR",serif;
  font-size:24px;
  letter-spacing:.16em;
  color:#fff;
}

.status{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  justify-content:flex-end;
}

.status span{
  border:1px solid rgba(200,163,90,.35);
  border-radius:999px;
  padding:8px 12px;
  font-size:11px;
  font-weight:800;
  letter-spacing:.08em;
  color:#f8e5b9;
  background:rgba(255,255,255,.04);
}

.wrap{
  max-width:1280px;
  margin:0 auto;
  display:grid;
  grid-template-columns:350px 1fr;
  gap:24px;
  align-items:start;
}

.panel{
  border:1px solid rgba(200,163,90,.28);
  border-radius:26px;
  padding:22px;
  background:linear-gradient(145deg,rgba(255,255,255,.12),rgba(255,255,255,.05));
  backdrop-filter:blur(16px);
  box-shadow:0 18px 45px rgba(0,0,0,.25);
}

.panel h2{
  font-size:18px;
  margin-bottom:6px;
  color:#fff;
}

.panel p{
  font-size:12px;
  line-height:1.6;
  color:#aebdd1;
  margin-bottom:18px;
}

.section-title{
  margin:22px 0 10px;
  padding-top:16px;
  border-top:1px solid rgba(200,163,90,.18);
  font-size:11px;
  font-weight:900;
  letter-spacing:.18em;
  color:var(--gold);
}

label{
  display:block;
  margin:12px 0 7px;
  font-size:12px;
  font-weight:800;
  color:#d9e6f7;
}

input,select{
  width:100%;
  padding:12px;
  border-radius:13px;
  border:1px solid rgba(190,210,235,.28);
  font-family:inherit;
  font-size:14px;
  background:rgba(255,255,255,.92);
  color:#10233f;
  outline:none;
}

input[type="color"]{
  height:44px;
  padding:4px;
}

input[type="range"]{
  padding:0;
  accent-color:var(--gold);
}

button{
  width:100%;
  padding:12px 10px;
  border:0;
  border-radius:14px;
  font-family:inherit;
  font-weight:900;
  font-size:13px;
  cursor:pointer;
  color:#081421;
  background:linear-gradient(135deg,#e7c979,#b98f3d);
  box-shadow:0 10px 24px rgba(200,163,90,.24);
}

button.sub{
  margin-top:10px;
  background:rgba(255,255,255,.1);
  color:#edf4ff;
  border:1px solid rgba(255,255,255,.16);
  box-shadow:none;
}

.btns{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-top:16px;
}

button.main{
  grid-column:1/3;
}

.preview-shell{
  border:1px solid rgba(200,163,90,.23);
  border-radius:32px;
  padding:22px;
  background:rgba(255,255,255,.07);
  backdrop-filter:blur(16px);
  box-shadow:0 20px 55px rgba(0,0,0,.24);
  overflow:auto;
}

.preview-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  margin-bottom:16px;
  color:#b9c8dc;
  font-size:12px;
  font-weight:800;
  letter-spacing:.12em;
}

.preview-top b{
  color:#f8e5b9;
}

.save-stage{
  display:inline-flex;
  gap:36px;
  padding:34px 42px;
  border-radius:34px;
  background:linear-gradient(135deg,#dbeaf6,#f6fbff);
  box-shadow:inset 0 0 0 1px rgba(255,255,255,.7);
}

.card{
  width:390px;
  height:620px;
  flex:0 0 390px;
  background:var(--paper);
  border-radius:28px;
  overflow:hidden;
  position:relative;
  box-shadow:0 18px 34px rgba(24,45,72,.22);
}

.card::after{
  content:"";
  position:absolute;
  inset:0;
  border-radius:28px;
  border:1px solid rgba(255,255,255,.75);
  pointer-events:none;
}

.top{
  height:88px;
  background:linear-gradient(145deg,var(--theme-dark),var(--theme));
  border-bottom:3px solid rgba(200,163,90,.72);
  display:flex;
  align-items:center;
  justify-content:center;
}

.brand h2{
  font-family:"Noto Serif KR",serif;
  color:white;
  font-size:31px;
  letter-spacing:.23em;
  text-shadow:0 2px 4px rgba(0,0,0,.25);
}

.content{
  position:relative;
  height:calc(100% - 88px);
  padding:30px 32px 28px;
}

.watermark{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  pointer-events:none;
  opacity:.075;
  filter:blur(.1px);
}

.watermark img{
  width:295px;
}

.front .watermark{
  align-items:flex-end;
  padding-bottom:112px;
}

.front .watermark img{
  width:270px;
}

.photo{
  position:relative;
  z-index:2;
  width:100%;
  height:245px;
  border-radius:17px;
  overflow:hidden;
  background:linear-gradient(135deg,#f1f5fa,#e5edf6);
  border:1px solid #cbd7e5;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#98a7ba;
  font-weight:800;
  font-size:14px;
}

.photo-img{
  position:absolute;
  left:50%;
  top:50%;
  max-width:none;
  max-height:none;
  width:100%;
  height:auto;
  transform:
    translate(-50%,-50%)
    translate(var(--photo-x),var(--photo-y))
    scale(var(--photo-scale));
  transform-origin:center center;
  user-select:none;
  pointer-events:none;
}

.info{
  position:relative;
  z-index:2;
  margin-top:34px;
}

.row{
  display:grid;
  grid-template-columns:140px 1fr;
  align-items:center;
  min-height:47px;
  border-bottom:1px solid rgba(200,163,90,.72);
}

.key{
  font-size:13px;
  font-weight:900;
  letter-spacing:.13em;
  color:#183354;
}

.value{
  font-size:17px;
  font-weight:800;
  color:#101b2c;
}

.cert{
  position:relative;
  z-index:2;
  height:100%;
  display:flex;
  flex-direction:column;
  text-align:center;
  color:#1a2230;
}

.cert-title{
  font-family:"Noto Serif KR",serif;
  font-size:22px;
  letter-spacing:.17em;
  color:var(--ink);
  margin:8px 0 12px;
}

.orn{
  display:flex;
  align-items:center;
  gap:10px;
  justify-content:center;
  color:var(--gold);
  margin-bottom:20px;
}

.orn::before,.orn::after{
  content:"";
  width:80px;
  height:1px;
  background:var(--gold);
  opacity:.65;
}

.star{
  font-size:16px;
}

.cert p{
  font-family:"Noto Serif KR",serif;
  font-size:15px;
  line-height:1.88;
  margin-bottom:21px;
  word-break:keep-all;
}

.bottom-line{
  display:flex;
  align-items:center;
  gap:10px;
  justify-content:center;
  color:var(--gold);
  margin-top:auto;
  margin-bottom:14px;
}

.bottom-line::before,.bottom-line::after{
  content:"";
  width:112px;
  height:1px;
  background:var(--gold);
  opacity:.65;
}

.agency{
  font-family:"Noto Serif KR",serif;
  font-size:12px;
  color:#1b2f50;
  text-align:center;
}

@media(max-width:1100px){
  .wrap{
    grid-template-columns:1fr;
  }
}

@media(max-width:620px){
  body{
    padding:14px;
  }
  .terminal-header{
    flex-direction:column;
    align-items:flex-start;
  }
  .save-stage{
    transform:scale(.72);
    transform-origin:top left;
    margin-bottom:-170px;
  }
}
</style>
</head>

<body>
<header class="terminal-header">
  <div class="header-title">
    <small>SABLE CENTRAL PROTECTION AGENCY</small>
    <h1>KEEPER IDENTIFICATION TERMINAL</h1>
  </div>
  <div class="status">
    <span>SYSTEM ONLINE</span>
    <span>AUTHORIZED</span>
    <span>WAVE STABLE</span>
  </div>
</header>

<div class="wrap">
  <aside class="panel">
    <h2>IDENTITY DATA</h2>
    <p>키퍼 인증서 발급 정보를 입력합니다. 사진 위치와 확대값은 미리보기 그대로 저장됩니다.</p>

    <div class="section-title">PHOTO CONTROL</div>

    <label>사진</label>
    <input type="file" id="photoInput" accept="image/*">

    <label>사진 확대</label>
    <input type="range" id="scaleInput" min="0.7" max="2.2" step="0.01" value="1">

    <label>사진 좌우 위치</label>
    <input type="range" id="xInput" min="-180" max="180" step="1" value="0">

    <label>사진 상하 위치</label>
    <input type="range" id="yInput" min="-180" max="180" step="1" value="0">

    <button class="sub" type="button" onclick="resetPhoto()">사진 위치 초기화</button>

    <div class="section-title">KEEPER INFORMATION</div>

    <label>이름</label>
    <input id="nameInput" value="">

    <label>나이</label>
    <input id="ageInput" value="">

    <label>키퍼 유형</label>
    <select id="typeInput">
      <option value=""></option>
      <option>계승 키퍼</option>
      <option>일반 키퍼</option>
    </select>

    <label>담당 코어</label>
    <input id="coreInput" value="">

    <label>상단 테마색</label>
    <input type="color" id="themeInput" value="#1f3a66">

    <div class="section-title">EXPORT</div>

    <div class="btns">
      <button onclick="saveOne('frontCard','SABLE_FRONT.png')">앞면 저장</button>
      <button onclick="saveOne('backCard','SABLE_BACK.png')">뒷면 저장</button>
      <button class="main" onclick="saveBoth()">앞/뒷면 합본 저장</button>
    </div>
  </aside>

  <main class="preview-shell">
    <div class="preview-top">
      <span>LIVE PREVIEW</span>
      <b>AUTHORIZED OUTPUT</b>
    </div>

    <div class="save-stage" id="saveStage">
      <section class="card front" id="frontCard">
        <div class="top">
          <div class="brand"><h2>SABLE</h2></div>
        </div>

        <div class="content">
          <div class="watermark">
            <img crossorigin="anonymous" src="https://i.ibb.co/cX6bHsLW/Chat-GPT-Image-2026-5-20-10-41-48.png">
          </div>

          <div class="photo" id="photoBox">PHOTO</div>

          <div class="info">
            <div class="row"><div class="key">NAME</div><div class="value" id="nameView"></div></div>
            <div class="row"><div class="key">AGE</div><div class="value" id="ageView"></div></div>
            <div class="row"><div class="key">KEEPER</div><div class="value" id="typeView"></div></div>
            <div class="row"><div class="key">ASSIGNED CORE</div><div class="value" id="coreView"></div></div>
          </div>
        </div>
      </section>

      <section class="card back" id="backCard">
        <div class="top">
          <div class="brand"><h2>SABLE</h2></div>
        </div>

        <div class="content">
          <div class="watermark">
            <img crossorigin="anonymous" src="https://i.ibb.co/cX6bHsLW/Chat-GPT-Image-2026-5-20-10-41-48.png">
          </div>

          <div class="cert">
            <div class="cert-title">OFFICIAL CERTIFICATE</div>
            <div class="orn"><span class="star">✦</span></div>

            <p>본 증명서는 SABLE 중앙 보호청에<br>
            정식 등록된 키퍼에게 발급되는<br>
            공식 신분 인증서입니다.</p>

            <div class="orn"><span class="star">✦</span></div>

            <p>소지자는 보호청 규정에 따라<br>
            담당 코어의 파장 안정화 및<br>
            긴급 보호 지원 임무를 수행할 수 있습니다.</p>

            <div class="orn"><span class="star">✦</span></div>

            <p>본 증명서는 등록된 본인에 한하여 유효하며,<br>
            타인에게 양도하거나 복제할 수 없습니다.</p>

            <div class="bottom-line"><span class="star">✦</span></div>
            <div class="agency">Sanctuary and Aid for Biological Life and Entities</div>
          </div>
        </div>
      </section>
    </div>
  </main>
</div>

<script>
function hexToRgb(hex){
  const clean = hex.replace("#","");
  const bigint = parseInt(clean,16);
  return {
    r:(bigint >> 16) & 255,
    g:(bigint >> 8) & 255,
    b:bigint & 255
  };
}

function darken(hex, amount = 42){
  const {r,g,b} = hexToRgb(hex);
  return `rgb(${Math.max(0,r-amount)}, ${Math.max(0,g-amount)}, ${Math.max(0,b-amount)})`;
}

function update(){
  nameView.textContent = nameInput.value;
  ageView.textContent = ageInput.value;
  typeView.textContent = typeInput.value;
  coreView.textContent = coreInput.value;

  document.documentElement.style.setProperty("--theme", themeInput.value);
  document.documentElement.style.setProperty("--theme-dark", darken(themeInput.value));
  document.documentElement.style.setProperty("--photo-scale", scaleInput.value);
  document.documentElement.style.setProperty("--photo-x", xInput.value + "px");
  document.documentElement.style.setProperty("--photo-y", yInput.value + "px");
}

[nameInput, ageInput, typeInput, coreInput, themeInput, scaleInput, xInput, yInput].forEach(el=>{
  el.addEventListener("input", update);
  el.addEventListener("change", update);
});

photoInput.addEventListener("change", e=>{
  const file = e.target.files[0];
  if(!file) return;

  const reader = new FileReader();
  reader.onload = ev => {
    photoBox.innerHTML = `<img class="photo-img" src="${ev.target.result}" alt="photo">`;
    resetPhoto();
  };
  reader.readAsDataURL(file);
});

function resetPhoto(){
  scaleInput.value = 1;
  xInput.value = 0;
  yInput.value = 0;
  update();
}

async function captureElement(element){
  await document.fonts.ready;

  return await html2canvas(element, {
    scale: 5,
    useCORS: true,
    allowTaint: true,
    backgroundColor: null,
    scrollX: 0,
    scrollY: 0,
    windowWidth: document.documentElement.scrollWidth,
    windowHeight: document.documentElement.scrollHeight
  });
}

async function saveOne(id, filename){
  const canvas = await captureElement(document.getElementById(id));
  const link = document.createElement("a");
  link.download = filename;
  link.href = canvas.toDataURL("image/png");
  link.click();
}

async function saveBoth(){
  const canvas = await captureElement(document.getElementById("saveStage"));
  const link = document.createElement("a");
  link.download = "SABLE_CARD_SET.png";
  link.href = canvas.toDataURL("image/png");
  link.click();
}

update();
</script>
</body>
</html>
